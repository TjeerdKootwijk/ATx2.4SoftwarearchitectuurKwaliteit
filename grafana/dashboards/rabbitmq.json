{
  "uid": "rabbitmq-overview",
  "title": "RabbitMQ Overview",
  "tags": ["rabbitmq"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 50, "type": "alertlist", "title": "Actieve alerts",
      "description": "Toont alerts die nu Firing of Pending zijn. Leeg betekent: alles gezond.",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 5 },
      "options": {
        "viewMode": "list",
        "groupMode": "default",
        "maxItems": 20,
        "sortOrder": 3,
        "dashboardAlerts": false,
        "alertInstanceLabelFilter": "",
        "stateFilter": { "firing": true, "pending": true, "error": true, "noData": false, "normal": false }
      }
    },

    { "id": 30, "type": "row", "title": "Queue Status per Queue", "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 31, "type": "stat", "title": "Main Queue",
      "description": "Aantal berichten in notification.queue (wachtend op verwerking).",
      "gridPos": { "x": 0, "y": 6, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "noValue": "0", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 500 }] } } },
      "targets": [{ "expr": "sum(rabbitmq_queue_messages{queue=\"notification.queue\"}) or vector(0)", "legendFormat": "Main", "refId": "A" }]
    },

    {
      "id": 32, "type": "stat", "title": "Retry 1 (5s)",
      "description": "Aantal berichten in retry queue 1 (wacht 5 seconden).",
      "gridPos": { "x": 4, "y": 6, "w": 3, "h": 4 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "noValue": "0", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }] } } },
      "targets": [{ "expr": "sum(rabbitmq_queue_messages{queue=\"notification.retry.queue.1\"}) or vector(0)", "legendFormat": "Retry 1", "refId": "A" }]
    },

    {
      "id": 33, "type": "stat", "title": "Retry 2 (30s)",
      "description": "Aantal berichten in retry queue 2 (wacht 30 seconden).",
      "gridPos": { "x": 7, "y": 6, "w": 3, "h": 4 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "noValue": "0", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }] } } },
      "targets": [{ "expr": "sum(rabbitmq_queue_messages{queue=\"notification.retry.queue.2\"}) or vector(0)", "legendFormat": "Retry 2", "refId": "A" }]
    },

    {
      "id": 34, "type": "stat", "title": "Retry 3 (2min)",
      "description": "Aantal berichten in retry queue 3 (wacht 2 minuten).",
      "gridPos": { "x": 10, "y": 6, "w": 3, "h": 4 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "noValue": "0", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }] } } },
      "targets": [{ "expr": "sum(rabbitmq_queue_messages{queue=\"notification.retry.queue.3\"}) or vector(0)", "legendFormat": "Retry 3", "refId": "A" }]
    },

    {
      "id": 35, "type": "stat", "title": "Retry 4 (5min)",
      "description": "Aantal berichten in retry queue 4 (wacht 5 minuten).",
      "gridPos": { "x": 13, "y": 6, "w": 3, "h": 4 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "noValue": "0", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }] } } },
      "targets": [{ "expr": "sum(rabbitmq_queue_messages{queue=\"notification.retry.queue.4\"}) or vector(0)", "legendFormat": "Retry 4", "refId": "A" }]
    },

    {
      "id": 36, "type": "stat", "title": "Retry 5 (10min)",
      "description": "Aantal berichten in retry queue 5 (wacht 10 minuten).",
      "gridPos": { "x": 16, "y": 6, "w": 3, "h": 4 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "noValue": "0", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }] } } },
      "targets": [{ "expr": "sum(rabbitmq_queue_messages{queue=\"notification.retry.queue.5\"}) or vector(0)", "legendFormat": "Retry 5", "refId": "A" }]
    },

    {
      "id": 37, "type": "stat", "title": "Dead Letter Queue",
      "description": "Aantal berichten dat permanent gefaald is (na alle retries).",
      "gridPos": { "x": 19, "y": 6, "w": 5, "h": 4 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "noValue": "0", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "targets": [{ "expr": "sum(rabbitmq_queue_messages{queue=\"notification.dead-letter.queue\"}) or vector(0)", "legendFormat": "DLQ", "refId": "A" }]
    },

    {
      "id": 38, "type": "timeseries", "title": "Queue Diepte Over Tijd",
      "description": "Aantal berichten per queue over tijd.",
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 8 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 5 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Main" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] },
          { "matcher": { "id": "byName", "options": "Retry 1 (5s)" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "Retry 2 (30s)" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
          { "matcher": { "id": "byName", "options": "Retry 3 (2min)" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } }] },
          { "matcher": { "id": "byName", "options": "Retry 4 (5min)" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "magenta" } }] },
          { "matcher": { "id": "byName", "options": "Retry 5 (10min)" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "dark-purple" } }] },
          { "matcher": { "id": "byName", "options": "Dead Letter" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum(rabbitmq_queue_messages{queue=\"notification.queue\"}) or vector(0)", "legendFormat": "Main", "refId": "A" },
        { "expr": "sum(rabbitmq_queue_messages{queue=\"notification.retry.queue.1\"}) or vector(0)", "legendFormat": "Retry 1 (5s)", "refId": "B" },
        { "expr": "sum(rabbitmq_queue_messages{queue=\"notification.retry.queue.2\"}) or vector(0)", "legendFormat": "Retry 2 (30s)", "refId": "C" },
        { "expr": "sum(rabbitmq_queue_messages{queue=\"notification.retry.queue.3\"}) or vector(0)", "legendFormat": "Retry 3 (2min)", "refId": "D" },
        { "expr": "sum(rabbitmq_queue_messages{queue=\"notification.retry.queue.4\"}) or vector(0)", "legendFormat": "Retry 4 (5min)", "refId": "E" },
        { "expr": "sum(rabbitmq_queue_messages{queue=\"notification.retry.queue.5\"}) or vector(0)", "legendFormat": "Retry 5 (10min)", "refId": "F" },
        { "expr": "sum(rabbitmq_queue_messages{queue=\"notification.dead-letter.queue\"}) or vector(0)", "legendFormat": "Dead Letter", "refId": "G" }
      ]
    },

    { "id": 1, "type": "row", "title": "Transactie Overzicht", "gridPos": { "x": 0, "y": 18, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 2, "type": "stat", "title": "Geslaagde Transacties",
      "description": "Totaal aantal notificaties dat succesvol verstuurd is door de consumer.",
      "gridPos": { "x": 0, "y": 19, "w": 8, "h": 6 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "noValue": "0", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "targets": [{ "expr": "sum(notifications_sent_total{job=\"spring-app\", status=\"success\"})", "legendFormat": "Geslaagd", "refId": "A" }]
    },

    {
      "id": 3, "type": "stat", "title": "Mislukte Transacties",
      "description": "Totaal aantal notificaties dat gefaald is door de consumer.",
      "gridPos": { "x": 8, "y": 19, "w": 8, "h": 6 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "targets": [{ "expr": "sum(notifications_sent_total{job=\"spring-app\", status=\"failed\"}) or vector(0)", "legendFormat": "Mislukt", "refId": "A" }]
    },

    {
      "id": 4, "type": "stat", "title": "Totaal Geprobeerd",
      "description": "Totaal aantal gepubliceerde berichten (geslaagd + mislukt).",
      "gridPos": { "x": 16, "y": 19, "w": 8, "h": 6 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [{ "expr": "sum(notifications_sent_total{job=\"spring-app\"}) or vector(0)", "legendFormat": "Totaal", "refId": "A" }]
    },

    { "id": 5, "type": "row", "title": "Notificatie Status & Fouten", "gridPos": { "x": 0, "y": 25, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 8, "type": "timeseries", "title": "Verstuurd vs Mislukt",
      "description": "Geslaagde vs mislukte notificaties per seconde (door de consumer).",
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 8 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Verstuurd (per sec)" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "Mislukt (per sec)" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum(rate(notifications_sent_total{job=\"spring-app\", status=\"success\"}[1m])) or vector(0)", "legendFormat": "Verstuurd (per sec)", "refId": "A" },
        { "expr": "sum(rate(notifications_sent_total{job=\"spring-app\", status=\"failed\"}[1m])) or vector(0)", "legendFormat": "Mislukt (per sec)", "refId": "B" }
      ]
    },

    { "id": 9, "type": "row", "title": "RabbitMQ Details", "gridPos": { "x": 0, "y": 34, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 10, "type": "stat", "title": "Connections",
      "gridPos": { "x": 0, "y": 35, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "targets": [{ "expr": "rabbitmq_connections{job=\"rabbitmq\"}", "legendFormat": "Connections", "refId": "A" }]
    },

    {
      "id": 11, "type": "stat", "title": "Channels",
      "gridPos": { "x": 4, "y": 35, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [{ "expr": "rabbitmq_channels{job=\"rabbitmq\"}", "legendFormat": "Channels", "refId": "A" }]
    },

    {
      "id": 12, "type": "stat", "title": "Queues",
      "gridPos": { "x": 8, "y": 35, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] } } },
      "targets": [{ "expr": "rabbitmq_queues{job=\"rabbitmq\"}", "legendFormat": "Queues", "refId": "A" }]
    },

    {
      "id": 13, "type": "stat", "title": "Consumers",
      "gridPos": { "x": 12, "y": 35, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] } } },
      "targets": [{ "expr": "rabbitmq_consumers{job=\"rabbitmq\"}", "legendFormat": "Consumers", "refId": "A" }]
    },

    {
      "id": 14, "type": "stat", "title": "Messages Ready",
      "gridPos": { "x": 16, "y": 35, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 1000 }] } } },
      "targets": [{ "expr": "sum(rabbitmq_queue_messages_ready{job=\"rabbitmq\"})", "legendFormat": "Ready", "refId": "A" }]
    },

    {
      "id": 15, "type": "stat", "title": "Messages Unacked",
      "gridPos": { "x": 20, "y": 35, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 100 }] } } },
      "targets": [{ "expr": "sum(rabbitmq_queue_messages_unacked{job=\"rabbitmq\"})", "legendFormat": "Unacked", "refId": "A" }]
    },

    {
      "id": 16, "type": "timeseries", "title": "Queued Messages",
      "gridPos": { "x": 0, "y": 39, "w": 24, "h": 8 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Ready" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "Unacked" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "Total" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum(rabbitmq_queue_messages_ready{job=\"rabbitmq\"})", "legendFormat": "Ready", "refId": "A" },
        { "expr": "sum(rabbitmq_queue_messages_unacked{job=\"rabbitmq\"})", "legendFormat": "Unacked", "refId": "B" },
        { "expr": "sum(rabbitmq_queue_messages{job=\"rabbitmq\"})", "legendFormat": "Total", "refId": "C" }
      ]
    },

    {
      "id": 17, "type": "timeseries", "title": "Message Rates",
      "gridPos": { "x": 0, "y": 47, "w": 24, "h": 8 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 5 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum(rate(rabbitmq_channel_messages_published_total{job=\"rabbitmq\"}[1m]))", "legendFormat": "Publish", "refId": "A" },
        { "expr": "sum(rate(rabbitmq_channel_messages_delivered_ack_total{job=\"rabbitmq\"}[1m]))", "legendFormat": "Deliver (auto ack)", "refId": "B" },
        { "expr": "sum(rate(rabbitmq_channel_messages_acknowledged_total{job=\"rabbitmq\"}[1m]))", "legendFormat": "Consumer ack", "refId": "C" },
        { "expr": "sum(rate(rabbitmq_channel_messages_redelivered_total{job=\"rabbitmq\"}[1m]))", "legendFormat": "Redelivered", "refId": "D" },
        { "expr": "sum(rate(rabbitmq_channel_messages_unroutable_dropped_total{job=\"rabbitmq\"}[1m]))", "legendFormat": "Unroutable (drop)", "refId": "E" }
      ]
    },

    {
      "id": 18, "type": "timeseries", "title": "Connection Operations",
      "gridPos": { "x": 0, "y": 55, "w": 8, "h": 6 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 5 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum(rate(rabbitmq_connections_opened_total{job=\"rabbitmq\"}[1m]))", "legendFormat": "Created", "refId": "A" },
        { "expr": "sum(rate(rabbitmq_connections_closed_total{job=\"rabbitmq\"}[1m]))", "legendFormat": "Closed", "refId": "B" }
      ]
    },

    {
      "id": 19, "type": "timeseries", "title": "Channel Operations",
      "gridPos": { "x": 8, "y": 55, "w": 8, "h": 6 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 5 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum(rate(rabbitmq_channels_opened_total{job=\"rabbitmq\"}[1m]))", "legendFormat": "Created", "refId": "A" },
        { "expr": "sum(rate(rabbitmq_channels_closed_total{job=\"rabbitmq\"}[1m]))", "legendFormat": "Closed", "refId": "B" }
      ]
    },

    {
      "id": 20, "type": "timeseries", "title": "Queue Operations",
      "gridPos": { "x": 16, "y": 55, "w": 8, "h": 6 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 5 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum(rate(rabbitmq_queue_declarations_total{job=\"rabbitmq\"}[1m]))", "legendFormat": "Declared", "refId": "A" },
        { "expr": "sum(rate(rabbitmq_queues_created_total{job=\"rabbitmq\"}[1m]))", "legendFormat": "Created", "refId": "B" },
        { "expr": "sum(rate(rabbitmq_queues_deleted_total{job=\"rabbitmq\"}[1m]))", "legendFormat": "Deleted", "refId": "C" }
      ]
    },

    { "id": 21, "type": "row", "title": "Applicatie Gezondheid & Foutmeldingen", "gridPos": { "x": 0, "y": 61, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 22, "type": "stat", "title": "Notificatie Fouten (laatste uur)",
      "description": "Aantal mislukte notificaties in het afgelopen uur (per provider).",
      "gridPos": { "x": 0, "y": 62, "w": 8, "h": 4 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "noValue": "0", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } } },
      "targets": [{ "expr": "round(sum(increase(notifications_sent_total{job=\"spring-app\", status=\"failed\"}[1h])) or vector(0))", "legendFormat": "Mislukt", "refId": "A" }]
    },

    {
      "id": 23, "type": "stat", "title": "JVM Geheugen",
      "description": "Percentage van het JVM heap-geheugen in gebruik.",
      "gridPos": { "x": 8, "y": 62, "w": 8, "h": 4 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "noValue": "0", "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] } } },
      "targets": [{ "expr": "(sum(jvm_memory_used_bytes{job=\"spring-app\", area=\"heap\"}) / sum(jvm_memory_max_bytes{job=\"spring-app\", area=\"heap\"}) * 100) or vector(0)", "legendFormat": "Heap %", "refId": "A" }]
    },

    {
      "id": 24, "type": "stat", "title": "CPU Gebruik",
      "description": "CPU-gebruik van het applicatieproces.",
      "gridPos": { "x": 16, "y": 62, "w": 8, "h": 4 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "noValue": "0", "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] } } },
      "targets": [{ "expr": "process_cpu_usage{job=\"spring-app\"} or vector(0)", "legendFormat": "CPU %", "refId": "A" }]
    },

    {
      "id": 25, "type": "timeseries", "title": "Notificatie Slagingspercentage",
      "description": "Mislukte vs geslaagde notificaties per seconde, opgesplitst per provider.",
      "gridPos": { "x": 0, "y": 66, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "/Mislukt.*/" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byRegexp", "options": "/Geslaagd.*/" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum by (provider) (rate(notifications_sent_total{job=\"spring-app\", status=\"failed\"}[1m])) or vector(0)", "legendFormat": "Mislukt - {{provider}}", "refId": "A" },
        { "expr": "sum by (provider) (rate(notifications_sent_total{job=\"spring-app\", status=\"success\"}[1m])) or vector(0)", "legendFormat": "Geslaagd - {{provider}}", "refId": "B" }
      ]
    },

    {
      "id": 26, "type": "timeseries", "title": "JVM Geheugen Over Tijd",
      "gridPos": { "x": 12, "y": 66, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Gebruikt" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] },
          { "matcher": { "id": "byName", "options": "Maximum" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum(jvm_memory_used_bytes{job=\"spring-app\", area=\"heap\"})", "legendFormat": "Gebruikt", "refId": "A" },
        { "expr": "sum(jvm_memory_max_bytes{job=\"spring-app\", area=\"heap\"})", "legendFormat": "Maximum", "refId": "B" }
      ]
    },

    { "id": 40, "type": "row", "title": "Performance & Provider HTTP-fouten", "gridPos": { "x": 0, "y": 74, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 41, "type": "stat", "title": "Gem. verwerkingstijd provider-call",
      "description": "Gemiddelde duur van een uitgaande provider-call over de laatste 5 minuten.",
      "gridPos": { "x": 0, "y": 75, "w": 8, "h": 5 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "noValue": "0", "unit": "s", "decimals": 3, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 3 }] } } },
      "targets": [{ "expr": "(sum(rate(http_client_requests_seconds_sum{job=\"spring-app\"}[5m])) / sum(rate(http_client_requests_seconds_count{job=\"spring-app\"}[5m]))) or vector(0)", "legendFormat": "Gem. latency", "refId": "A" }]
    },

    {
      "id": 42, "type": "stat", "title": "Provider server-fouten (5xx, laatste uur)",
      "description": "Aantal provider-calls met een 5xx-status in het afgelopen uur. Wijst op een provider die down is of intern faalt.",
      "gridPos": { "x": 8, "y": 75, "w": 8, "h": 5 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "noValue": "0", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "targets": [{ "expr": "round(sum(increase(http_client_requests_seconds_count{job=\"spring-app\", status=~\"5..\"}[1h])) or vector(0))", "legendFormat": "5xx", "refId": "A" }]
    },

    {
      "id": 43, "type": "stat", "title": "Provider rate limiting (429, laatste uur)",
      "description": "Aantal provider-calls dat met HTTP 429 (Too Many Requests) is geweigerd in het afgelopen uur.",
      "gridPos": { "x": 16, "y": 75, "w": 8, "h": 5 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "noValue": "0", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "targets": [{ "expr": "round(sum(increase(http_client_requests_seconds_count{job=\"spring-app\", status=\"429\"}[1h])) or vector(0))", "legendFormat": "429", "refId": "A" }]
    },

    {
      "id": 45, "type": "timeseries", "title": "Provider HTTP-status over tijd",
      "description": "Snelheid van uitgaande provider-calls per HTTP-statuscode. Pieken in 4xx/5xx wijzen op provider-problemen.",
      "gridPos": { "x": 0, "y": 80, "w": 24, "h": 8 },
      "datasource": { "uid": "prometheus-rabbitmq", "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum by (status) (rate(http_client_requests_seconds_count{job=\"spring-app\"}[1m])) or vector(0)", "legendFormat": "{{status}}", "refId": "A" }]
    },

    { "id": 27, "type": "row", "title": "Applicatie Logs", "gridPos": { "x": 0, "y": 88, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 28, "type": "logs", "title": "Errors & Warnings (laatste 10 min)",
      "description": "Alleen ERROR en WARN logs van de communicatiemodule.",
      "gridPos": { "x": 0, "y": 89, "w": 24, "h": 20 },
      "datasource": { "uid": "loki", "type": "loki" },
      "timeFrom": "10m",
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": false, "showCommonLabels": false, "showLabels": false, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true },
      "targets": [{ "expr": "{service_name=\"atx24-app\"} | detected_level=~\"error|warn\"", "legendFormat": "", "refId": "A", "maxLines": 200 }]
    },

    {
      "id": 29, "type": "logs", "title": "Info & Debug Logs (laatste 10 min)",
      "description": "Alleen INFO en DEBUG logs van de communicatiemodule via OpenTelemetry.",
      "gridPos": { "x": 0, "y": 109, "w": 24, "h": 20 },
      "datasource": { "uid": "loki", "type": "loki" },
      "timeFrom": "10m",
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": false, "showCommonLabels": false, "showLabels": false, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true },
      "targets": [{ "expr": "{service_name=\"atx24-app\"} | detected_level !~ \"error|warn\"", "legendFormat": "", "refId": "A", "maxLines": 200 }]
    }

  ]
}
