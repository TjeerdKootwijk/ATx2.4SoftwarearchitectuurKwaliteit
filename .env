
#postgres

# AES-256 encryption key for sensitive database columns (NFR5).
# Must be exactly 32 bytes, Base64-encoded.
# Generate a new key with: openssl rand -base64 32
# NEVER commit a production key to version control.
AES_ENCRYPTION_KEY=EZLzg025mt6HbHesB93kP1X60RMYml1fsNY76P1ibpQ=

#RabbitMQ

#OpenMRS Tenant 1 — fake-openmrs (pipeline testen)
OPENMRS_BASE_URL=http://host.docker.internal:8090
OPENMRS_USERNAME=admin
OPENMRS_PASSWORD=Admin123
OPENMRS_TENANT_ID=fake-ziekenhuis
OPENMRS_ORGANIZATION_NAME=Fake Ziekenhuis
OPENMRS_NOTIFICATION_PROVIDER=SECUREPOST
OPENMRS_TIMEZONE=Europe/Amsterdam

# OpenMRS Tenant 2 — echte OpenMRS instantie
OPENMRS2_TENANT_ID=echt-ziekenhuis
OPENMRS2_ORGANIZATION_NAME=Echt Ziekenhuis
OPENMRS2_BASE_URL=http://host.docker.internal:80/openmrs
OPENMRS2_USERNAME=admin
OPENMRS2_PASSWORD=Admin123
OPENMRS2_NOTIFICATION_PROVIDER=SWIFTSEND
OPENMRS2_TIMEZONE=UTC

# Fake OpenMRS — configuratie voor pipeline-tests
FAKE_APPOINTMENT_COUNT_1H=3
FAKE_APPOINTMENT_COUNT_24H=3

FAKE_APPOINTMENT_HOURS_1H=0
FAKE_APPOINTMENT_HOURS_24H=21

FAKE_PATIENT_NAME=Jan de Vriezer
FAKE_APPOINTMENT_LOCATION=Polikliniek Kamer 3B
FAKE_APPOINTMENT_TYPE=Consultatie
FAKE_APPOINTMENT_STATUS=Scheduled
FAKE_APPOINTMENT_COMMENTS=Niet eten van te voren

#App

#MessageProviders


PROVIDER_BASE_URL=https://fakecomworld.endpoint
PROVIDER_STUDENT_GROUP=openmrs-communication-module
PROVIDER_STUDENT_API_KEY=1234567890

#AsyncFlow
PROVIDERS_ASYNCFLOW_API_KEY=asyncflow-api-key
PROVIDERS_ASYNCFLOW_DEFAULT_PRIORITY=normal
