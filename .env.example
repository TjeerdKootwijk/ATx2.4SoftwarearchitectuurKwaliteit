# Kopieer dit bestand naar .env en vul de waarden in:
#   cp .env.example .env
#
# Variabelen die al zijn ingesteld in docker-compose.yml hoef je hier niet te herhalen
# (zoals database- en RabbitMQ-verbindingen). Vul hieronder alleen de waarden in
# die specifiek zijn voor jouw omgeving.

# ─────────────────────────────────────────────
# Versleuteling (verplicht)
# ─────────────────────────────────────────────

# AES-256 sleutel voor het versleutelen van gevoelige databasekolommen (NFR5).
# Moet exact 32 bytes zijn, Base64-gecodeerd.
# Genereer een nieuwe sleutel met: openssl rand -base64 32
# Commit NOOIT een productiesleutel naar versiebeheer.
AES_ENCRYPTION_KEY=

# ─────────────────────────────────────────────
# OpenMRS koppeling
# ─────────────────────────────────────────────

# Tenant identificatie voor jouw OpenMRS-organisatie
OPENMRS_TENANT_ID=mijn-ziekenhuis
OPENMRS_ORGANIZATION_NAME=Mijn Ziekenhuis

# URL van de OpenMRS-instantie waarmee de module verbinding maakt.
# Gebruik host.docker.internal als OpenMRS lokaal op de host draait.
OPENMRS_BASE_URL=http://host.docker.internal:80/openmrs

# Inloggegevens voor de OpenMRS REST API (Basic Auth)
OPENMRS_USERNAME=admin
OPENMRS_PASSWORD=

# Messaging provider die gebruikt wordt voor notificaties.
# Kies uit: SWIFTSEND, LEGACYLINK, ASYNCFLOW, SECUREPOST
OPENMRS_NOTIFICATION_PROVIDER=SWIFTSEND

# Tijdzone van de organisatie (IANA ID, bijv. "Europe/Amsterdam").
# Bepaalt wanneer de 24u- en 1u-notificaties worden verstuurd (NFR13).
OPENMRS_TIMEZONE=Europe/Amsterdam

# ─────────────────────────────────────────────
# Messaging providers (API-sleutels)
# ─────────────────────────────────────────────

# SwiftSend
PROVIDERS_SWIFTSEND_API_KEY=

# LegacyLink (geen extra sleutel vereist buiten de base URL)

# AsyncFlow
PROVIDERS_ASYNCFLOW_API_KEY=
PROVIDERS_ASYNCFLOW_DEFAULT_PRIORITY=normal

# SecurePost
PROVIDERS_SECUREPOST_CLIENT_ID=
PROVIDERS_SECUREPOST_CLIENT_SECRET=

# ─────────────────────────────────────────────
# Nep-OpenMRS (alleen voor lokale tests)
# ─────────────────────────────────────────────
# Deze variabelen sturen de nep-OpenMRS server aan die meekomt in docker-compose.
# Aanpassen is alleen nodig als je specifieke testscenarios wilt simuleren.

# Aantal nep-afspraken over ca. 1 uur (triggert de 1u-notificatie)
FAKE_APPOINTMENT_COUNT_1H=2

# Aantal nep-afspraken over ca. 24 uur (triggert de 24u-notificatie)
FAKE_APPOINTMENT_COUNT_24H=2

# Exacte tijdverschillen in uren
FAKE_APPOINTMENT_HOURS_1H=0
FAKE_APPOINTMENT_HOURS_24H=21

# Inhoud van de nep-afspraken
FAKE_PATIENT_NAME=Jan de Vries
FAKE_APPOINTMENT_LOCATION=Polikliniek Kamer 3B
FAKE_APPOINTMENT_TYPE=Consultatie
FAKE_APPOINTMENT_STATUS=Scheduled
FAKE_APPOINTMENT_COMMENTS=Nuchter komen
